{
  "name": "uwestjs-benchmarks",
  "version": "1.0.0",
  "private": true,
  "description": "Performance benchmarks for uWestJS",
  "engines": {
    "node": ">=24.0.0 <=25"
  },
  "scripts": {
    "start": "node run.js",
    "benchmark": "node run.js --duration 20 --output results.md",
    "benchmark:quick": "node run.js --duration 10",
    "benchmark:detailed": "node run.js --duration 20 --output results.md && node generate-detailed-report.js",
    "benchmark:save": "node save-history.js",
    "benchmark:compare": "node compare-history.js",
    "test": "node test-setup.js"
  },
  "keywords": [
    "benchmark",
    "performance",
    "uwestjs"
  ],
  "author": "Vikram Aditya",
  "license": "MIT",
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/static": "^8.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "compression": "^1.8.1",
    "express": "^4.21.2",
    "fastify": "^5.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  }
}

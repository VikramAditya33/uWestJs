{
  "name": "uwestjs",
  "version": "1.0.1",
  "description": "High-performance HTTP and WebSocket platform adapter for NestJS using uWebSockets.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns='.integration.spec.ts'",
    "test:integration": "jest --testPathPattern='.integration.spec.ts'",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write 'src/**/*.{ts,js,json,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json,md}'",
    "prepare": "husky",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "nestjs",
    "uwestjs",
    "http",
    "websocket",
    "uwebsockets",
    "uws",
    "websockets",
    "realtime",
    "performance",
    "adapter",
    "gateway",
    "socket.io",
    "concurrency",
    "ws"
  ],
  "author": "Vikram Aditya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FOSSFORGE/uWestJS.git"
  },
  "bugs": {
    "url": "https://github.com/FOSSFORGE/uWestJS/issues"
  },
  "homepage": "https://github.com/FOSSFORGE/uWestJS#readme",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "@nestjs/common": "^9.0.0 || ^10.0.0 || ^11.0.0",
    "@nestjs/websockets": "^9.0.0 || ^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "compressible": "^2.0.18",
    "content-disposition": "^1.1.0",
    "cookie": "^1.1.1",
    "cookie-signature": "^1.2.2",
    "etag": "^1.8.1",
    "mime-types": "^3.0.2",
    "ms": "^2.1.3",
    "range-parser": "^1.2.1",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.65.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@types/busboy": "^1.5.4",
    "@types/compressible": "^2.0.3",
    "@types/content-disposition": "^0.5.8",
    "@types/cookie-signature": "^1.1.2",
    "@types/etag": "^1.8.4",
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/range-parser": "^1.2.7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^17.4.0",
    "husky": "^9.0.0",
    "jest": "^30.0.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.0.0",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=24.0.0 <=25"
  }
}
